{
  "name": "amazon-observer",
  "version": "1.0.0",
  "description": "Amazon & Mercado Livre Deals Observer - Scraper automático de ofertas",
  "main": "src/observer.js",
  "scripts": {
    "start": "node src/observer.js",
    "observer": "node src/observer.js",

    "schedule": "node src/scheduler.js",
    "schedule:test": "node src/scheduler.js --run-now",
    "schedule:test:ml": "node src/scheduler.js --run-now --ml",

    "affiliate:test": "node src/pages/test-affiliate.js",

    "history": "node src/manage-history.js",
    "history:stats": "node src/manage-history.js stats",
    "history:list": "node src/manage-history.js list",
    "history:clear": "node src/manage-history.js clear",

    "pm2:start": "pm2 start src/scheduler.js --name deals-scheduler",
    "pm2:start:observer": "pm2 start src/observer.js --name deals-observer",
    "pm2:stop": "pm2 stop deals-scheduler",
    "pm2:restart": "pm2 restart deals-scheduler",
    "pm2:logs": "pm2 logs deals-scheduler",
    "pm2:status": "pm2 status",
    "pm2:delete": "pm2 delete deals-scheduler"
  },
  "keywords": [
    "amazon",
    "mercadolivre",
    "scraper",
    "deals",
    "observer",
    "automation",
    "affiliate"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "node-cron": "^4.2.1",
    "openai": "^6.32.0",
    "puppeteer": "^24.36.1",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7"
  }
}